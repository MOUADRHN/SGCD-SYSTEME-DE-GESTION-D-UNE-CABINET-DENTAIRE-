<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>SGCD - Cabinet Dentaire</display-name>

    <!--
        Connexion MySQL configurée dans :
        src/main/java/ma/fst/sgcd/util/DBUtil.java
        Modifier les constantes URL, USER, PASSWORD dans ce fichier.
    -->

    <!-- ─── Filtre d'authentification ──────────────────────────────────── -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>ma.fst.sgcd.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ─── Page d'accueil ─────────────────────────────────────────────── -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ─── Pages d'erreur ─────────────────────────────────────────────── -->
    <error-page>
        <error-code>404</error-code>
        <location>/views/common/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/common/error500.jsp</location>
    </error-page>

    <!-- ─── Session : timeout 30 minutes ─────────────────────────────── -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
